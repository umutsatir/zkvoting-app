    let ecdsa_sig: [u8; 64]   = [254, 141, 30, 177, 188, 179, 67, 43, 29, 181, 131, 63, 245, 242, 34, 109, 156, 181, 230, 92, 238, 67, 5, 88, 193, 142, 211, 163, 200, 108, 225, 175, 125, 201, 153, 38, 230, 140, 182, 196, 44, 101, 91, 42, 197, 181, 130, 82, 222, 25, 185, 179, 5, 165, 195, 118, 118, 89, 188, 40, 14, 91, 85, 145];

